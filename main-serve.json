{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "$ref": "#/definitions/main-serve",
    "definitions": {
        "main-serve": {
            "type": "object",
            "description": "Main Serve - Full YAML Configuration Schema",
            "additionalProperties": false,
            "properties": {
                "server": {
                    "$ref": "#/definitions/Server",
                    "description": "Main Serve core server settings. These settings affect core HTTP server behavior"
                },
                "logging": {
                    "$ref": "#/definitions/Logging",
                    "description": "Main Serve logging settings."
                },
                "cors": {
                    "$ref": "#/definitions/Cors",
                    "description": "CORS (Global defaults - can be overridden per-endpoint)"
                },
                "rate_limit": {
                    "$ref": "#/definitions/RateLimit",
                    "description": "RATE LIMITING (Global defaults - can be overridden per-endpoint)"
                },
                "databases": {
                    "$ref": "#/definitions/Databases",
                    "description": "DATABASES\nNamed database connections. At least one is required for CRUD endpoints."
                },
                "tables": {
                    "$ref": "#/definitions/Tables",
                    "description": "TABLE SCHEMAS\nDefine database tables. Used for auto-migration and CRUD query generation."
                },
                "auth": {
                    "$ref": "#/definitions/Auth",
                    "description": "AUTHENTICATION (Global auth provider definitions)\nDefine named auth providers. Endpoints reference these by name."
                },
                "endpoints": {
                    "type": "array",
                    "description": "The core of Main Serve. Each entry in the endpoints list defines an HTTP route and its behavior.\nDefine API routes, static file serving paths, and reverse proxies.",
                    "items": {
                        "$ref": "#/definitions/Endpoint"
                    }
                }
            },
            "required": [
                "endpoints",
                "server"
            ],
            "title": "Main Serve"
        },
        "Auth": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "jwt": {
                    "$ref": "#/definitions/Jwt",
                    "description": "JWT authentication provider."
                },
                "api_key": {
                    "$ref": "#/definitions/APIKey",
                    "description": "API key authentication."
                },
                "basic": {
                    "$ref": "#/definitions/Basic",
                    "description": "HTTP Basic authentication."
                },
                "oauth2": {
                    "$ref": "#/definitions/Oauth2",
                    "description": "OAuth2 / OpenID Connect authentication.\nSupports two modes:\n  1. Token introspection: validate externally-obtained Bearer tokens via userinfo_url. Endpoints use `auth: \"oauth2\"`.\n  2. Authorization code flow (with PKCE): Main Serve redirects users to the IdP for login, exchanges the code for tokens, fetches user info, mints a Main Serve JWT, and sets it as an HttpOnly cookie. This bridges OAuth2 into the existing JWT auth model. Requires auth.jwt to be configured alongside oauth2.\n\nCode flow endpoints (registered automatically when authorization_url is set):\n  GET /_main-serve/oauth2/authorize  - redirects to IdP\n  GET /_main-serve/oauth2/callback   - handles IdP callback"
                }
            },
            "title": "Auth"
        },
        "APIKey": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "location": {
                    "type": "string",
                    "description": "Where to look for the API key: \"header\" or \"query\".",
                    "enum": [ "header", "query" ],
                    "default": "header"
                },
                "name": {
                    "type": "string",
                    "description": "Header name or query parameter name.",
                    "default": "X-API-Key"
                },
                "keys": {
                    "type": "array",
                    "description": "List of valid API keys (use ${ENV_VAR} for each).\nEach key can optionally have a role attached.",
                    "items": {
                        "$ref": "#/definitions/Key"
                    }
                }
            },
            "required": [
                "keys",
                "location",
                "name"
            ],
            "title": "APIKey"
        },
        "Key": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "key": {
                    "type": "string",
                    "description": "An API key.",
                    "examples": [ "${API_KEY_1}", "${API_KEY_2}" ]
                },
                "role": {
                    "type": "string",
                    "description": "Any applicable role.",
                    "examples": [ "admin", "reader" ]
                }
            },
            "title": "Key"
        },
        "Basic": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "realm": {
                    "type": "string",
                    "description": "Realm string returned in WWW-Authenticate header.",
                    "default": "main-serve"
                },
                "users": {
                    "type": "array",
                    "description": "List of username/password pairs (passwords must be argon2 hashes).",
                    "items": {
                        "$ref": "#/definitions/User"
                    }
                }
            },
            "required": [
                "users"
            ],
            "title": "Basic"
        },
        "User": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "username": {
                    "type": "string",
                    "description": "Username for basic auth.",
                    "examples": [ "admin", "someuser" ]
                },
                "password_hash": {
                    "type": "string",
                    "description": "A password hash for the named user.",
                    "examples": [ "${ADMIN_PASSWORD_HASH}" ]
                },
                "role": {
                    "type": "string",
                    "description": "The user's role.",
                    "examples": [ "admin", "reader" ]
                }
            },
            "required": [
                "password_hash",
                "role",
                "username"
            ],
            "title": "User"
        },
        "Jwt": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "secret": {
                    "type": "string",
                    "description": "Secret key for HMAC signing, or path to public key for RSA/EC. (Use ${ENV_VAR})"
                },
                "algorithm": {
                    "type": "string",
                    "description": "JWT algorithm. Leave unspecified for default (HS256).",
                    "enum": [
                        "HS256",
                        "HS384",
                        "HS512",
                        "RS256",
                        "RS384",
                        "RS512",
                        "ES256",
                        "ES384"
                    ],
                    "default": "HS256"
                },
                "issuer": {
                    "type": "string",
                    "description": "Token issuer (iss claim).",
                    "default": "main-serve"
                },
                "audience": {
                    "type": "string",
                    "description": "Expected audience (aud claim). Optional.",
                    "default": ""
                },
                "expiry": {
                    "type": "integer",
                    "description": "Token expiry duration in seconds.",
                    "default": 3600
                },
                "role_claim": {
                    "type": "string",
                    "description": "Name of the claim that contains the user's role.",
                    "default": "role"
                }
            },
            "required": [
                "secret"
            ],
            "title": "Jwt"
        },
        "Oauth2": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "provider": {
                    "type": "string",
                    "description": "OAuth2 provider name (for logging/identification)."
                },
                "authorization_url": {
                    "type": "string",
                    "description": "Authorization endpoint URL (IdP's login page). Optional (defaults to empty string). When set, enables the OAuth2 authorization code flow and registers the /_main-serve/oauth2/authorize and callback endpoints."
                },
                "token_url": {
                    "type": "string",
                    "description": "Token endpoint URL (where the code is exchanged for tokens).\nRequired when authorization_url is set."
                },
                "userinfo_url": {
                    "type": "string",
                    "description": "UserInfo endpoint URL (OIDC). Optional (defaults to empty string).\nUsed to validate bearer tokens (mode 1) and to fetch user info after code exchange (mode 2). Returns JSON with \"sub\" and optional \"role\" fields."
                },
                "client_id": {
                    "type": "string",
                    "description": "Client ID registered with the OAuth2 provider.\nRequired when authorization_url is set.",
                    "examples": [
                        "${OAUTH2_CLIENT_ID}"
                    ]
                },
                "client_secret": {
                    "type": "string",
                    "description": "Client secret registered with the OAuth2 provider.\nRequired when authorization_url is set.",
                    "examples": [
                        "${OAUTH2_CLIENT_SECRET}"
                    ]
                },
                "scopes": {
                    "type": "array",
                    "description": "OAuth2 scopes to request during the authorization code flow.",
                    "items": {
                        "type": "string"
                    }
                },
                "redirect_url": {
                    "type": "string",
                    "description": "Callback URL that the IdP redirects to after authentication. Must match the redirect URI registered with the OAuth2 provider.\nRequired when authorization_url is set.",
                    "format": "uri",
                    "qt-uri-protocols": [
                        "http",
                        "https"
                    ],
                    "examples": [
                        "http://localhost:8080/_main-serve/oauth2/callback"
                    ]
                },
                "success_url": {
                    "type": "string",
                    "description": "URL to redirect the user to after successful OAuth2 login. (Path or full URL).",
                    "format": "uri",
                    "qt-uri-protocols": [
                        "http",
                        "https"
                    ],
                    "examples": [
                        "https://example.com",
                        "/"
                    ],
                    "default": "/"
                },
                "cookie_name": {
                    "type": "string",
                    "description": "Name of the HttpOnly cookie set after a successful OAuth2 login.\n Contains the minted JWT. The JWT auth middleware also checks this cookie, so endpoints with `auth: \"jwt\"` work seamlessly after login.",
                    "default": "main_serve_token"
                },
                "state_ttl": {
                    "type": "integer",
                    "description": "Maximum lifetime (in seconds) for a pending OAuth2 authorization state.\nStates older than this are expired and rejected during the callback.",
                    "default": 300
                },
                "max_pending_states": {
                    "type": "integer",
                    "description": "Maximum number of pending OAuth2 authorization flows allowed simultaneously.\nLimits memory usage from concurrent or abandoned authorization flows.",
                    "default": 1000
                }
            },
            "dependentRequired": {
                "authorization_url": [
                    "token_url",
                    "client_id",
                    "client_secret",
                    "redirect_url"
                ]
            },
            "title": "Oauth2"
        },
        "Cors": {
            "type": [ "object", "null" ],
            "additionalProperties": false,
            "properties": {
                "allowed_origins": {
                    "type": "array",
                    "description": "Allowed origins. Use [\"*\"] to allow all.",
                    "items": {
                        "type": "string"
                    },
                    "default": "[\"*\"]"
                },
                "allowed_methods": {
                    "type": "array",
                    "description": "Allowed HTTP methods.",
                    "items": {
                        "type": "string",
                        "enum": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD" ]
                    },
                    "default": "[\"GET\", \"POST\", \"PUT\", \"PATCH\", \"DELETE\", \"OPTIONS\", \"HEAD\"]"
                },
                "allowed_headers": {
                    "type": "array",
                    "description": "Allowed request headers.",
                    "items": {
                        "type": "string"
                    },
                    "default": "[\"*\"]"
                },
                "allow_credentials": {
                    "type": "boolean",
                    "description": "Whether to allow credentials (cookies, authorization headers).",
                    "default": "false"
                },
                "max_age": {
                    "type": "integer",
                    "description": "Max age for preflight cache in seconds.",
                    "default": 86400
                }
            },
            "title": "Cors"
        },
        "Databases": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
                "^.*$": {
                    "$ref": "#/definitions/Database",
                    "description": "Each key is a unique name used to reference this database in endpoints."
                }
            },
            "title": "Databases"
        },
        "Database": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "driver": {
                    "type": "string",
                    "description": "Database driver: postgres, mysql, sqlite",
                    "enum": [ "postgres", "mysql", "sqlite" ]
                },
                "url": {
                    "type": "string",
                    "description": "Connection string / URL. (Use ${ENV_VAR} for secrets)",
                    "examples": [
                      "${DATABASE_URL}"
                    ]
                },
                "min_connections": {
                    "type": "integer",
                    "description": "Minimum number of connections in the pool.",
                    "default": 1
                },
                "max_connections": {
                    "type": "integer",
                    "description": "Maximum number of connections in the pool.",
                    "default": 10
                },
                "auto_migrate": {
                    "type": "boolean",
                    "description": "Whether to run auto-migrations on startup/reload for tables that reference this database.",
                    "default": true
                },
                "allow_destructive": {
                    "type": "boolean",
                    "description": "Whether auto-migration is allowed to drop columns that exist in the database but are no longer present in the YAML config.\nWhen false (the default), removed columns are logged as warnings but left untouched - no data is lost.\nWhen true, columns missing from the YAML config will be dropped from the database via ALTER TABLE ... DROP COLUMN. THIS IS DESTRUCTIVE and cannot be undone.",
                    "default": false
                },
                "acquire_timeout": {
                    "type": "integer",
                    "description": "Pool connection acquire timeout in seconds.\nHow long to wait for a connection from the pool before returning an error.",
                    "default": 5
                }
            },
            "required": [
                "driver",
                "url"
            ],
            "title": "Database"
        },
        "Endpoint": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "path": {
                    "type": "string",
                    "description": "The path for the endpoint.",
                    "examples": [
                        "/static"
                    ]
                },
                "methods": {
                    "type": "array",
                    "description": "Supported HTTP verbs.",
                    "items": {
                        "type": "string",
                        "enum": [
                            "get", "post", "put", "patch", "delete"
                        ]
                    }  
                },
                "action": {
                    "type": "string",
                    "description": "Type of action to perform.",
                    "enum": [
                        "crud",
                        "proxy",
                        "static",
                        "custom_response"
                    ]  
                },
                "crud": {
                    "$ref": "#/definitions/CRUD",
                    "description": "CRUD-specific configuration (required when action is \"crud\")."
                },
                "auth": {
                    "type": "string",
                    "description": "Authentication required for this endpoint.\nMust be the name of an auth provider configured in the `auth` section or \"none\" for no auth.",
                    "default": "none"
                },
                "roles": {
                    "type": "array",
                    "description": "Authorization: which roles are allowed to access this endpoint. If omitted, any authenticated user is allowed",
                    "items": {
                        "type": "string"
                    }
                },
                "cors": {
                    "$ref": "#/definitions/Cors",
                    "description": "Per-endpoint CORS override (same shape as global cors)."
                },
                "rate_limit": {
                    "$ref": "#/definitions/RateLimit",
                    "description": "Per-endpoint rate limiting override (same shape as global rate_limit)."
                },
                "proxy": {
                    "$ref": "#/definitions/Proxy",
                    "description": "Proxy-specific configuration (required when action is \"proxy\")."
                },
                "static_files": {
                    "$ref": "#/definitions/StaticFiles",
                    "description": "Static file serving configuration (required when action is \"static\")."
                },
                "custom_response": {
                    "$ref": "#/definitions/CustomResponse",
                    "description": "Custom response configuration (required when action is \"custom_response\")."
                }
            },
            "required": [
                "action",
                "methods",
                "path"
            ],
            "if": {
                "action": "crud"
            },
            "then": {
                "action": [ "crud" ]
            },
            "else": {
                "if": {
                    "action": "proxy"
                },
                "then": {
                    "action": [ "proxy" ]
                },
                "else": {
                    "if": {
                        "action": "static"
                    },
                    "then": {
                        "action": [ "static_files" ]
                    },
                    "else": {
                        "if": {
                            "action": "custom_response"
                        },
                        "then": {
                            "action": [ "custom_response" ]
                        }
                    }
                }
            },
            "title": "Endpoint"
        },
        "CRUD": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "table": {
                    "type": "string",
                    "description": "Which table to operate on (must match a key in `tables`)."
                },
                "database": {
                    "type": "string",
                    "description": "Which named database to use (must match a key in `databases`). Optional.\nIf not set, inherited from the table's `database` setting, or 'main' if neither is set."
                },
                "fields": {
                    "type": "array",
                    "description": "Fields to return in GET responses. Use [\"*\"] for all.",
                    "items": {
                        "type": "string"
                    },
                    "default": "[\"*\"]"
                },
                "writable_fields": {
                    "type": "array",
                    "description": "Fields that are writable on POST/PUT/PATCH. Omit to allow all non-PK fields.",
                    "items": {
                        "type": "string"
                    }
                },
                "pagination": {
                    "$ref": "#/definitions/Pagination",
                    "description": "Enable pagination on GET list endpoints."
                },
                "filtering": {
                    "$ref": "#/definitions/Filtering",
                    "description": "Enable filtering on GET list endpoints (query parameters become WHERE clauses)."
                },
                "sorting": {
                    "$ref": "#/definitions/Sorting",
                    "description": "Enable sorting on GET list endpoints (?sort=field&order=asc)."
                },
                "where_clause": {
                    "type": [ "string", "null" ],
                    "description": "Static WHERE clause applied to all queries on this endpoint.",
                    "examples": [ "deleted_at IS NULL" ],
                    "default": null
                },
                "joins": {
                    "type": "array",
                    "description": "Joins with other tables.",
                    "items": {
                        "$ref": "#/definitions/Join"
                    }
                },
                "computed_fields": {
                    "type": "array",
                    "description": "Computed / virtual fields (SQL expressions).",
                    "items": {
                        "$ref": "#/definitions/Computed"
                    }
                }
            },
            "required": [
                "table"
            ],
            "title": "CRUD"
        },
        "Filtering": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Whether filtering is enabled.",
                    "default": true
                },
                "allowed_fields": {
                    "type": "array",
                    "description": "Columns that can be filtered on.",
                    "items": {
                        "type": "string"
                    },
                    "default": "[\"*\"]"
                }
            },
            "title": "Filtering"
        },
        "Join": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "table": {
                    "type": "string",
                    "description": "The table to join with this one."
                },
                "on": {
                    "type": "string",
                    "description": "The fields to join on.",
                    "examples": [ "users.org_id = organizations.id" ]
                },
                "type": {
                    "type": "string",
                    "description": "The type of join.",
                    "enum": [ "inner", "left", "right" ]
                },
                "fields": {
                    "type": "array",
                    "description": "Fields from the other table to include.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "table",
                "on",
                "type",
                "fields"
            ]
        },
        "Computed": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Computed field name.",
                    "examples": [ "full_name" ]
                },
                "expression": {
                    "type": "string",
                    "description": "Expression to evaluate.",
                    "examples": [ "first_name || ' ' || last_name" ]
                }
            },
            "required": [ "name", "expression" ]
        },
        "Pagination": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Whether pagination is enabled.",
                    "default": true
                },
                "default_page_size": {
                    "type": "integer",
                    "description": "Default page size.",
                    "default": 20
                },
                "max_page_size": {
                    "type": "integer",
                    "description": "Maximum allowed page size.",
                    "default": 100
                }
            },
            "title": "Pagination"
        },
        "Sorting": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Whether sorting is enabled.",
                    "default": true
                },
                "default_field": {
                    "type": "string",
                    "description": "Default field to sort on.",
                    "default": "created_at"
                },
                "default_order": {
                    "type": "string",
                    "description": "Default sort order.",
                    "enum": [ "asc", "desc" ],
                    "default": "desc"                    
                },
                "allowed_fields": {
                    "type": "array",
                    "description": "Fields that can be sorted on. Defaults to all.",
                    "items": {
                        "type": "string"
                    },
                    "default": "[\"*\"]"
                }
            },
            "title": "Sorting"
        },
        "CustomResponse": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "status": {
                    "type": "integer",
                    "description": "HTTP status code.",
                    "default": 200
                },
                "content_type": {
                    "type": "string",
                    "description": "Response content type.",
                    "default": "application/json"
                },
                "body": {
                    "type": "string",
                    "description": "Response body (inline string).",
                    "examples": [
                        "{\"name\": \"Main Serve\", \"version\": \"0.1.0\"}"
                    ]
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "Response headers to include. Consists of arbitrary X-* keys and their values.",
                    "patternProperties": {
                        "^.*$": {
                            "type": "string",
                            "description": "An individual header to add to the response."
                        }
                    },
                    "default": "{}",
                    "examples": [ "X-Custom-A: \"hello\"", "X-Custom-B: \"world\"" ]
                }
            },
            "required": [ "body" ],
            "title": "CustomResponse"
        },
        "Proxy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "upstream": {
                    "type": "string",
                    "description": "Upstream base URL to forward requests to.",
                    "format": "uri",
                    "qt-uri-protocols": [
                        "http",
                        "https"
                    ]
                },
                "path_rewrite": {
                    "$ref": "#/definitions/PathRewrite",
                    "description": "Path rewrite rules."
                },
                "headers": {
                    "$ref": "#/definitions/ProxyHeaders",
                    "description": "Headers to add to the upstream request."
                },
                "timeouts": {
                    "$ref": "#/definitions/Timeouts",
                    "description": "Timeout settings."
                },
                "max_response_size": {
                    "type": "integer",
                    "description": "Maximum upstream response body size in bytes. Responses exceeding this limit are rejected to prevent memory exhaustion.\nSet to 0 to disable the limit.",
                    "default": 268435456
                }
            },
            "required": [
                "upstream"
            ],
            "title": "Proxy"
        },
        "ProxyHeaders": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
                "^.*$": {
                    "type": "string",
                    "description": "An individual header to add to the upstream request."
                }
            },
            "examples": [
                "X-Forwarded-For: \"client\"",
                "Authorization: \"Bearer ${UPSTREAM_TOKEN}\""
            ],
            "default": "{}",
            "title": "ProxyHeaders"
        },
        "PathRewrite": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "strip_prefix": {
                    "type": "string",
                    "description": "Strip this prefix from the request path before forwarding.",
                    "examples": [ "/api/external" ]
                },
                "add_prefix": {
                    "type": "string",
                    "description": "Prepend this prefix to the path before forwarding.",
                    "examples": [ "/v2" ]
                }
            },
            "title": "PathRewrite"
        },
        "Timeouts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "connect": {
                    "type": "integer",
                    "description": "Connect timeout.",
                    "default": 5
                },
                "read": {
                    "type": "integer",
                    "description": "Read timeout",
                    "default": 30
                },
                "total": {
                    "type": "integer",
                    "description": "Maximum total time for the proxied request.",
                    "default": 60
                }
            },
            "title": "Timeouts"
        },
        "StaticFiles": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "root": {
                    "type": "string",
                    "description": "Root directory for static files (relative to CWD or absolute).",
                    "examples": [
                        "./public",
                        "/var/www"
                    ]
                },
                "index": {
                    "type": "string",
                    "description": "Default index file for directory requests.",
                    "default": "index.html",
                    "examples": [ "index.html" ]
                },
                "directory_listing": {
                    "type": "boolean",
                    "description": "Whether to show directory listings when no index file is found.",
                    "default": false
                },
                "cache_max_age": {
                    "type": "integer",
                    "description": "Cache-Control header max-age in seconds. 0 disables caching.",
                    "default": 3600
                },
                "spa_fallback": {
                    "type": "boolean",
                    "description": "SPA fallback: if true, 404s for non-file paths return the index file\nThis enables display of SPAs, such as those created with React, Angular, and other frameworks/libraries.",
                    "default": false
                }
            },
            "required": [
                "root"
            ],
            "title": "StaticFiles"
        },
        "Logging": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "level": {
                    "type": "string",
                    "description": "Log level: trace, debug, info, warn, error",
                    "enum": [ "trace", "debug", "info", "warn", "error" ],
                    "default": "info"
                },
                "format": {
                    "type": "string",
                    "description": "Output format: \"json\" or \"pretty\"",
                    "enum": [ "json", "pretty" ],
                    "default": "pretty"
                },
                "log_request_body": {
                    "type": "boolean",
                    "description": "Whether to log request bodies (can be verbose / contain sensitive data).\nBodies are logged at the DEBUG level. Bodies larger than 16 KiB are truncated in the log output. The body is buffered in memory for logging and then replayed to the handler, so enabling this adds memory overhead.",
                    "default": false
                },
                "log_response_body": {
                    "type": "boolean",
                    "description": "Whether to log response bodies.\nBodies are logged at the DEBUG level. Bodies larger than 16 KiB are truncated in the log output. The response body is buffered in memory for logging before being sent to the client.",
                    "default": false
                },
                "max_body_log_size": {
                    "type": "integer",
                    "description": "Maximum body size (in bytes) that will be included in log output.\nBodies larger than this are truncated. Applies to both request and response body logging.",
                    "default": 16384
                }
            },
            "title": "Logging"
        },
        "RateLimit": {
            "type": [ "object", "null" ],
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Whether rate limiting is enabled globally.",
                    "default": false
                },
                "max_requests": {
                    "type": "integer",
                    "description": "Maximum number of requests per window.",
                    "default": 100
                },
                "window_seconds": {
                    "type": "integer",
                    "description": "Window duration in seconds.",
                    "default": 60
                },
                "key_strategy": {
                    "type": "string",
                    "description": "Key extraction strategy:\n  - ip: rate limit by client IP\n  - header: rate limit by value of a specific header (set key_header)\n  - token: rate limit by auth token / API key",
                    "enum": [ "ip", "header", "token" ],
                    "default": "ip"
                },
                "key_header": {
                    "type": "string",
                    "description": "Header name to use when key_strategy is \"header\".",
                    "default": null
                },
                "cleanup_threshold": {
                    "type": "integer",
                    "description": "Number of tracked client entries before triggering cleanup of expired entries.\nIncrease for high-traffic deployments with many unique clients.",
                    "default": 10000
                }
            },
            "if": {
              "properties": {
                "key_strategy": { "const": "header" }
              }
            },
            "then": {
              "required": [ "key_header" ]
            },
            "else": {
              "required": []
            },
            "title": "RateLimit"
        },
        "Server": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "host": {
                    "type": "string",
                    "description": "Bind address for the HTTP listener. Default: \"127.0.0.1\"",
                    "default": "\"127.0.0.1\""
                },
                "port": {
                    "type": "integer",
                    "description": "Port number for the HTTP listener.",
                    "default" : 8080
                },
                "workers": {
                    "type": "integer",
                    "description": "Number of worker threads. Set to 0 or omit for auto (num CPUs).",
                    "default": "0"
                },
                "max_body_size": {
                    "type": "integer",
                    "description": "Maximum request body size in bytes. Requests exceeding this are rejected with 413.",
                    "default": 10485760
                },
                "keep_alive": {
                    "type": "integer",
                    "description": "HTTP keep-alive timeout in seconds. 0 disables keep-alive.\nWhen > 0, idle keep-alive connections are closed after this many seconds\nwithout a new request (implemented via hyper's header_read_timeout).",
                    "default": 75
                },
                "shutdown_timeout": {
                    "type": "integer",
                    "description": "Graceful shutdown timeout in seconds.\nAfter receiving SIGTERM/SIGINT, in-flight requests have this long to complete.",
                    "default": 30
                },
                "tls": {
                    "$ref": "#/definitions/TLS",
                    "description": "TLS configuration. Omit this section entirely to serve plain HTTP."
                }
            },
            "title": "Server"
        },
        "TLS": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "cert": {
                    "type": "string",
                    "description": "Path to PEM-encoded certificate file",
                    "examples": [
                      "/path/to/cert.pem"
                    ]
                },
                "key": {
                    "type": "string",
                    "description": "Path to PEM-encoded private key file.",
                    "examples": [
                      "/path/to/key.pem"
                    ]
                }
            },
            "required": [
                "cert",
                "key"
            ],
            "title": "TLS"
        },
        "Tables": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
                "^.*$": {
                    "$ref": "#/definitions/Table",
                    "description": "Each key is the table name."
                }
            },
            "title": "Tables"
        },
        "Table": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "database": {
                    "type": "string",
                    "description": "Which named database this table belongs to (must match a key in `databases`)."
                },
                "columns": {
                    "type": "array",
                    "description": "Column definitions. Every table must have at least one primary key column.",
                    "items": {
                        "$ref": "#/definitions/Column"
                    }
                },
                "foreign_keys": {
                    "type": "array",
                    "description": "Foreign key constraints.",
                    "items": {
                        "$ref": "#/definitions/ForeignKey"
                    }
                }
            },
            "required": [
                "columns",
                "database"
            ],
            "title": "Table"
        },
        "Column": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Column name as it will appear in the database."
                },
                "type": {
                    "type": "string",
                    "description": "Column data type.",
                    "enum": [
                        "integer",
                        "bigint",
                        "smallint",
                        "serial",
                        "bigserial",
                        "text",
                        "varchar",
                        "char",
                        "boolean",
                        "float",
                        "double",
                        "decimal",
                        "date",
                        "timestamp",
                        "timestamptz",
                        "uuid",
                        "json",
                        "jsonb",
                        "blob",
                        "bytea"
                    ]
                },
                "primary_key": {
                    "type": "boolean",
                    "description": "Whether this column is the primary key.",
                    "default": false
                },
                "nullable": {
                    "type": "boolean",
                    "description": "Whether this column can be NULL.\n(Primary key columns ignore this setting and are always treated as NOT NULL.)",
                    "default": true
                },
                "default": {
                    "type": [ "string", "null" ],
                    "description": "Default value or SQL expression for this column.",
                    "examples": [ "now()", "'active'", "0" ]
                },
                "unique": {
                    "type": "boolean",
                    "description": "Whether to create a UNIQUE constraint.",
                    "default": false
                },
                "indexed": {
                    "type": "boolean",
                    "description": "Whether to create an index on this column.",
                    "default": false
                }
            },
            "required": [
                "name",
                "type"
            ],
            "title": "Column"
        },
        "ForeignKey": {
            "type":"object",
            "properties": {
                "column": {
                    "type": "string",
                    "description": "The name of the column in this table to associate with a column in another table."
                },
                "references_table": {
                    "type": "string",
                    "description": "The name of the referenced table."
                },
                "references_column": {
                    "type": "string",
                    "description": "The name of the referenced column."
                },
                "on_delete": {
                    "type": "string",
                    "description": "Action to perform on deleting a record.",
                    "enum": [ "cascade", "set_null", "restrict", "no_action" ],
                    "default": "restrict"
                },
                "on_update": {
                    "type": "string",
                    "description": "Action to perform on updating a record.",
                    "enum": [ "cascade", "set_null", "restrict", "no_action" ],
                    "default": "restrict"
                }
            },
            "required": [
                "column",
                "references_table",
                "references_column"
            ]
        }
    }
}
